{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/memory_dream_hook.py --event session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/memory_dream_hook.py --event stop",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
