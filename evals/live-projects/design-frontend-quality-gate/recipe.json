{
  "project": "design-frontend-quality-gate",
  "description": "A small DesignDNA-to-frontend quality gate with tokens, accessible rendering, and anti-slop checks.",
  "required_skills": [
    "design-craft-gate",
    "designdna",
    "design-templates",
    "anti-slop",
    "frontend-patterns",
    "browser-automation",
    "output-quality-gate"
  ],
  "acceptance": {
    "required_files": [
      "AGENTS.md",
      "PRODUCT.md",
      "DESIGN.md",
      "design/tokens.json",
      "docs/design-quality.md",
      "docs/shape-brief.md",
      "src/render_dashboard.py",
      "tests/test_dashboard_quality.py"
    ],
    "required_content": [
      {
        "path": "docs/design-quality.md",
        "patterns": ["design-craft-gate", "PRODUCT.md", "DESIGN.md", "DesignDNA", "brand", "quality", "accessibility", "responsive", "anti-pattern"]
      },
      {
        "path": "docs/shape-brief.md",
        "patterns": ["Shape Brief", "Surface", "User goal", "Evidence"]
      },
      {
        "path": "src/render_dashboard.py",
        "patterns": ["aria-label", "grid-template-columns", "DesignDNA", "PRODUCT.md", "DESIGN.md"]
      }
    ],
    "forbidden_content": [
      {
        "path": "src/render_dashboard.py",
        "patterns": ["letter-spacing: -", "gradient orb", "bokeh", "manual svg hero", "bg-clip-text", "animate-bounce"]
      }
    ],
    "commands": [
      {
        "id": "design-preflight",
        "argv": ["{root}/bin/super-skill", "design-preflight", "--project", ".", "--strict", "--json"]
      },
      {
        "id": "design-extract",
        "argv": ["{root}/bin/super-skill", "design-extract", "--project", "src", "--write-sidecar", ".super-skill/design/design.json", "--write-design", ".super-skill/design/DESIGN.generated.md", "--json"]
      },
      {
        "id": "design-live",
        "argv": ["{root}/bin/super-skill", "design-live", "--project", "src", "--target-url", "http://localhost:3000", "--output", ".super-skill/design/live.html", "--json"]
      },
      {
        "id": "design-live-panel-check",
        "argv": ["{python}", "-c", "from pathlib import Path\nhtml=Path('.super-skill/design/live.html').read_text(encoding='utf-8')\nassert 'getComputedStyle' in html\nassert 'data-ss-design-overlay' in html\nassert 'Live Variant' in html\nassert 'contrast' in html"]
      },
      {
        "id": "design-live-extension",
        "argv": ["{root}/bin/super-skill", "design-live", "--project", "src", "--target-url", "http://localhost:3000", "--write-extension", ".super-skill/design/extension", "--json"]
      },
      {
        "id": "design-live-extension-check",
        "argv": ["{python}", "-c", "from pathlib import Path\nimport json\nroot=Path('.super-skill/design/extension')\nmanifest=json.loads((root/'manifest.json').read_text(encoding='utf-8'))\nassert manifest['manifest_version'] == 3\nassert (root/'overlay.js').exists()\nassert (root/'popup.html').exists()\nassert 'getComputedStyle' in (root/'overlay.js').read_text(encoding='utf-8')"]
      },
      {
        "id": "design-capture-dry-run",
        "argv": ["{root}/bin/super-skill", "design-capture", "--project", ".", "--url", "http://localhost:3000", "--runner", ".super-skill/design/capture.mjs", "--dry-run", "--json"]
      },
      {
        "id": "design-capture-runner-check",
        "argv": ["{python}", "-c", "from pathlib import Path\nrunner=Path('.super-skill/design/capture.mjs').read_text(encoding='utf-8')\nassert 'import(\"playwright\")' in runner\nassert 'page.evaluate(overlay)' in runner\nassert 'page.screenshot' in runner\nassert 'super-skill.design-capture.report.v1' in runner"]
      },
      {
        "id": "design-audit",
        "argv": ["{root}/bin/super-skill", "design-audit", "--project", "src", "--fail-on-findings", "--json"]
      },
      {
        "id": "dashboard-quality-tests",
        "argv": ["{python}", "-m", "unittest", "discover", "-s", "tests"]
      }
    ],
    "memory_hook": true
  }
}
