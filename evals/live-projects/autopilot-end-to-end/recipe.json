{
  "project": "autopilot-end-to-end",
  "description": "Run bin/super-skill autopilot in stub mode against an empty workspace and verify the 12-phase needs-to-commercial-delivery loop produces every artifact, the run journal is green, the quality gate passes, business case + launch + pilot + commercial-delivery + ops artifacts are present, and the ops retrospective is review-only (no raw user prompt).",
  "required_skills": [
    "autopilot",
    "requirement-analysis",
    "intent-contract",
    "business-case",
    "product-spec",
    "design-templates",
    "ralph-loop",
    "code-simplifier",
    "output-quality-gate",
    "deployment-patterns",
    "experiment-driven-delivery",
    "agent-memory-dream-loop",
    "harness-engineering",
    "checkpoint-rollback-safety"
  ],
  "acceptance": {
    "required_files": [
      "README.md",
      ".super-skill/autopilot/*/run.json",
      ".super-skill/autopilot/*/00-research.md",
      ".super-skill/autopilot/*/01-intent-contract.md",
      ".super-skill/autopilot/*/02-business-case.md",
      ".super-skill/autopilot/*/03-product-spec.md",
      ".super-skill/autopilot/*/04-design.md",
      ".super-skill/autopilot/*/05-implementation.md",
      ".super-skill/autopilot/*/06-simplified.md",
      ".super-skill/autopilot/*/07-quality-gate.json",
      ".super-skill/autopilot/*/08-launch-readiness.md",
      ".super-skill/autopilot/*/09-pilot.md",
      ".super-skill/autopilot/*/10-commercial-delivery.md",
      ".super-skill/autopilot/*/11-ops-retrospective.md"
    ],
    "required_content": [
      {
        "path": ".super-skill/autopilot/*/00-research.md",
        "patterns": ["problem statement", "target users", "assumptions", "trace"]
      },
      {
        "path": ".super-skill/autopilot/*/01-intent-contract.md",
        "patterns": ["goal", "acceptance", "evidence", "trace"]
      },
      {
        "path": ".super-skill/autopilot/*/02-business-case.md",
        "patterns": ["market sizing", "roi", "risk", "recommendation"]
      },
      {
        "path": ".super-skill/autopilot/*/07-quality-gate.json",
        "patterns": ["\"verdict\": \"pass\"", "\"matches_intent\": true"]
      },
      {
        "path": ".super-skill/autopilot/*/08-launch-readiness.md",
        "patterns": ["dockerfile", "ci workflow", "kill switch", "rollback", "release notes"]
      },
      {
        "path": ".super-skill/autopilot/*/09-pilot.md",
        "patterns": ["pilot cohort", "success metrics", "rollback triggers", "decision rule"]
      },
      {
        "path": ".super-skill/autopilot/*/10-commercial-delivery.md",
        "patterns": ["acceptance checklist", "sla", "billing", "training", "signoff"]
      },
      {
        "path": ".super-skill/autopilot/*/11-ops-retrospective.md",
        "patterns": ["use when", "do not use when", "expiry", "ops dashboard", "iteration roadmap"]
      },
      {
        "path": ".super-skill/autopilot/*/run.json",
        "patterns": ["\"ok\": true", "\"failed_phase\": null"]
      }
    ],
    "forbidden_content": [
      {
        "path": ".super-skill/autopilot/*/11-ops-retrospective.md",
        "patterns": [
          "raw prompt",
          "secret prompt verbatim",
          "feedback-loop-secret-token"
        ]
      }
    ],
    "setup_commands": [
      {
        "id": "autopilot-stub-run",
        "timeout": 90,
        "argv": [
          "{python}",
          "{root}/scripts/super_skill.py",
          "autopilot",
          "--provider",
          "stub",
          "--project",
          ".",
          "--prompt",
          "Build a Python add(a,b) function with one unit test. Trace marker: feedback-loop-secret-token"
        ]
      }
    ]
  }
}
