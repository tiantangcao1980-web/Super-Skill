{
  "project": "autopilot-end-to-end",
  "description": "Run bin/super-skill autopilot in stub mode against an empty workspace and verify the 7-phase closed loop produces every artifact, the run journal is green, the quality gate passes, and the memory candidate is review-only (no raw user prompt).",
  "required_skills": [
    "autopilot",
    "intent-contract",
    "product-spec",
    "design-templates",
    "ralph-loop",
    "code-simplifier",
    "output-quality-gate",
    "agent-memory-dream-loop",
    "harness-engineering",
    "checkpoint-rollback-safety"
  ],
  "acceptance": {
    "required_files": [
      "README.md",
      ".super-skill/autopilot/*/run.json",
      ".super-skill/autopilot/*/01-intent-contract.md",
      ".super-skill/autopilot/*/02-product-spec.md",
      ".super-skill/autopilot/*/03-design.md",
      ".super-skill/autopilot/*/04-implementation.md",
      ".super-skill/autopilot/*/05-simplified.md",
      ".super-skill/autopilot/*/06-quality-gate.json",
      ".super-skill/autopilot/*/07-memory-candidate.md"
    ],
    "required_content": [
      {
        "path": ".super-skill/autopilot/*/01-intent-contract.md",
        "patterns": ["goal", "acceptance", "evidence", "trace"]
      },
      {
        "path": ".super-skill/autopilot/*/06-quality-gate.json",
        "patterns": ["\"verdict\": \"pass\"", "\"matches_intent\": true"]
      },
      {
        "path": ".super-skill/autopilot/*/07-memory-candidate.md",
        "patterns": ["use when", "do not use when", "expiry"]
      },
      {
        "path": ".super-skill/autopilot/*/run.json",
        "patterns": ["\"ok\": true", "\"failed_phase\": null"]
      }
    ],
    "forbidden_content": [
      {
        "path": ".super-skill/autopilot/*/07-memory-candidate.md",
        "patterns": [
          "raw prompt",
          "secret prompt verbatim",
          "feedback-loop-secret-token"
        ]
      }
    ],
    "setup_commands": [
      {
        "id": "autopilot-stub-run",
        "timeout": 90,
        "argv": [
          "{python}",
          "{root}/scripts/super_skill.py",
          "autopilot",
          "--provider",
          "stub",
          "--project",
          ".",
          "--prompt",
          "Build a Python add(a,b) function with one unit test. Trace marker: feedback-loop-secret-token"
        ]
      }
    ]
  }
}
