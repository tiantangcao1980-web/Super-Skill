      400,
      500,
      600,
      700
    ]
  },
  "spacing": {
    "space-1": "2px",
    "space-2": "3px",
    "space-3": "4px",
    "space-4": "6px",
    "space-5": "8px",
    "space-6": "10px",
    "space-7": "11px",
    "space-8": "12px",
    "space-9": "15px",
    "space-10": "16px"
  },
  "radius": {
    "radius-1": "8px",
    "radius-2": "14px"
  },
  "shadows": {
    "card-shadow": "rgba(0,0,0,0.02",
    "hover-shadow": "rgba(0,0,0,0.08"
  },
  "dials": {
    "formality": 4,
    "motion": 5,
    "density": 5,
    "warmth": 9,
