  "typography": {
    "families": [
      "Airbnb Cereal VF",
      "Circular",
      "OpenType Features",
      "salt"
    ],
    "sizes": {
      "section-heading": "28px",
      "card-heading": "22px",
      "card-heading-medium": "22px",
      "sub-heading": "21px",
      "feature-title": "20px",
      "ui-medium": "16px",
      "ui-semibold": "16px",
