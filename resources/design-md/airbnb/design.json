{
  "brand": "airbnb",
  "version": "1.0.0",
  "$schema": "https://designdna.dev/schemas/tokens-v1.json",
  "colors": {
    "rausch-red": "#ff385c",
    "deep-rausch": "#e00b41",
    "error-red": "#c13515",
    "error-dark": "#b32505",
    "luxe-purple": "#460479",
    "plus-magenta": "#92174d",
    "near-black": "#222222",
    "focused-gray": "#3f3f3f",
    "secondary-gray": "#6a6a6a",
    "disabled": "rgba(0, 0, 0, 0.24)",
    "link-disabled": "#929292",
    "legal-blue": "#428bff",
    "border-gray": "#c1c1c1",
    "light-surface": "#f2f2f2",
    "pure-white": "#ffffff",
    "card-shadow": "rgba(0, 0, 0, 0.02)",
    "hover-shadow": "rgba(0, 0, 0, 0.08)"
