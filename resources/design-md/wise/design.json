{
  "brand": "wise",
  "version": "1.0.0",
  "$schema": "https://designdna.dev/schemas/tokens-v1.json",
  "colors": {
    "near-black": "#0e0f0c",
    "wise-green": "#9fe870",
    "dark-green": "#163300",
    "light-mint": "#e2f6d5",
    "pastel-green": "#cdffad",
    "positive-green": "#054d28",
    "danger-red": "#d03238",
    "warning-yellow": "#ffd11a",
    "background-cyan": "rgba(56, 200, 255, 0.10)",
    "bright-orange": "#ffc091",
    "warm-dark": "#454745",
    "gray": "#868685",
    "light-surface": "#e8ebe6"
  },
  "typography": {
    "families": [
      "Wise Sans",
      "Inter",
      "calt",
      "Helvetica"
    ],
    "sizes": {
      "display": "126px",
      "hero": "96px",
      "section-heading": "64px",
      "sub-heading": "40px",
      "alt-heading": "78px",
