    },
    "weights": [
      400,
      600,
      900
    ]
  },
  "spacing": {
    "space-1": "2px",
    "space-2": "3px",
    "space-3": "4px",
    "space-4": "5px",
    "space-5": "8px",
    "space-6": "10px",
    "space-7": "11px",
    "space-8": "12px",
    "space-9": "16px",
    "space-10": "18px"
  },
  "radius": {
    "radius-1": "9999px",
    "radius-2": "16px"
  },
  "shadows": {
    "shadow-1": "rgba(14,15,12,0.12) 0px 0px 0px 1px",
    "shadow-2": "rgb(134,134,133) 0px 0px 0px 1px inset"
  },
  "dials": {
    "formality": 6,
    "motion": 4,
    "density": 5,
    "warmth": 7,
    "contrast": 6
