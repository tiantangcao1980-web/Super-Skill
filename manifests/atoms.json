    "version": "v1",
    "vocabulary": [
      "critique.score",
      "iterations",
      "user.confirmed",
      "preview.ok",
      "tests.pass",
      "verdict.pass"
    ],
    "note": "Plugins MUST only use these signal names in `until:` expressions. Unknown signals cause `bin/super-skill atoms --validate` to fail."
  },
